---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  date?: Date;
  backHref?: string;
  backLabel?: string;
}

const { title, description, date, backHref, backLabel = "Back" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="prose prose-invert prose-neutral max-w-none">
    {
      backHref && (
        <a href={backHref} class="text-sm text-neutral-400 hover:text-neutral-200 no-underline mb-8 inline-block">
          ← {backLabel}
        </a>
      )
    }
    <header class="mb-10 not-prose">
      <h1 class="text-3xl font-bold text-neutral-100 mb-2">{title}</h1>
      {description && <p class="text-neutral-400 text-lg">{description}</p>}
      {
        date && (
          <time class="text-sm text-neutral-500 mt-2 block">
            {date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        )
      }
    </header>
    <slot />
  </article>
</BaseLayout>
