---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../../layouts/ContentLayout.astro";
import PasswordGate from "../../../components/PasswordGate.astro";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({ params: { slug: recipe.id }, props: { recipe } }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, description, category, servings, prepTime, cookTime, ingredients } = recipe.data;
---

<ContentLayout title={title} description={description} backHref="/hobbies/baking" backLabel="Baking">
  <div class="not-prose grid grid-cols-3 gap-4 mb-8 text-sm">
    <div class="p-4 rounded-lg bg-neutral-900 border border-neutral-800">
      <div class="text-neutral-500 mb-1">Prep</div>
      <div class="text-neutral-200 font-medium">{prepTime}</div>
    </div>
    <div class="p-4 rounded-lg bg-neutral-900 border border-neutral-800">
      <div class="text-neutral-500 mb-1">Cook</div>
      <div class="text-neutral-200 font-medium">{cookTime}</div>
    </div>
    <div class="p-4 rounded-lg bg-neutral-900 border border-neutral-800">
      <div class="text-neutral-500 mb-1">Serves</div>
      <div class="text-neutral-200 font-medium">{servings}</div>
    </div>
  </div>

  <h2>Ingredients</h2>
  <ul>
    {ingredients.map((ing) => <li>{ing}</li>)}
  </ul>

  <h2>Method</h2>
  {recipe.data.password ? (
    <PasswordGate password={recipe.data.password}>
      <Content />
    </PasswordGate>
  ) : (
    <Content />
  )}
</ContentLayout>
