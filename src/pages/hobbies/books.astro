---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Books" description="Books I'm reading and have read.">
  <a href="/hobbies" class="text-sm text-neutral-400 hover:text-neutral-200 mb-8 inline-block">← Hobbies</a>
  <h1 class="text-3xl font-bold text-neutral-100 mb-2">Books</h1>
  <p class="text-neutral-400 mb-8">
    I track my reading on Goodreads. You can follow along or see my shelf there.
  </p>
  <a
    href="https://www.goodreads.com"
    class="inline-block text-sm text-neutral-300 border border-neutral-700 rounded px-4 py-2 hover:border-neutral-500 transition-colors"
  >
    View my Goodreads shelf →
  </a>
</BaseLayout>
