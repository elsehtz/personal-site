---
import BaseLayout from "../layouts/BaseLayout.astro";

const sections = [
  {
    href: "/blog",
    label: "Blog",
    description: "Infrequent writing on tech, politics, and things worth sharing.",
  },
  {
    href: "/software",
    label: "Software",
    description: "Projects, open source work, AI experiments, and my resume.",
  },
  {
    href: "/builds",
    label: "Builds",
    description: "Physical projects — circuits, PCBs, 3D prints, DIY builds, and woodworking.",
  },
  {
    href: "/hobbies",
    label: "Hobbies",
    description: "Boxing, baking, and books.",
  },
];
---

<BaseLayout title="zak" description="Personal site">
  <section class="py-16">
    <h1 class="text-4xl font-bold text-neutral-100 mb-3">Hey, I'm Zak</h1>
    <p class="text-neutral-400 text-lg max-w-xl mb-16">
      Software engineer, amateur boxer, and maker of things. This is where I document the work and interests that
      matter to me.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        sections.map(({ href, label, description }) => (
          <a
            href={href}
            class="p-6 rounded-lg border border-neutral-800 hover:border-neutral-600 transition-colors group"
          >
            <h2 class="font-semibold text-neutral-100 group-hover:text-white mb-2 transition-colors">{label}</h2>
            <p class="text-sm text-neutral-400">{description}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
