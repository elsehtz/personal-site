---
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-800 py-8">
  <div class="max-w-4xl mx-auto px-4 flex items-center justify-between text-sm text-neutral-500">
    <span>© {year}</span>
    <div class="flex gap-4">
      <a href="https://github.com" class="hover:text-neutral-300 transition-colors">GitHub</a>
      <a href="https://www.goodreads.com" class="hover:text-neutral-300 transition-colors">Goodreads</a>
    </div>
  </div>
</footer>
