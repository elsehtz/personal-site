---
interface Props {
  password: string;
}

const { password } = Astro.props;
---

<div id="pg-gate">
  <div class="max-w-sm mx-auto mt-12 p-6 rounded-lg bg-neutral-900 border border-neutral-800">
    <h2 class="text-lg font-semibold text-neutral-200 mb-2">Protected Content</h2>
    <p class="text-neutral-400 text-sm mb-4">Enter the password to view this content.</p>
    <form id="pg-form" class="flex flex-col gap-3">
      <input
        id="pg-input"
        type="password"
        placeholder="Password"
        class="bg-neutral-800 border border-neutral-700 rounded px-3 py-2 text-neutral-100 placeholder-neutral-500 focus:outline-none focus:border-neutral-500"
      />
      <button
        type="submit"
        class="bg-neutral-700 hover:bg-neutral-600 text-neutral-100 rounded px-4 py-2 text-sm font-medium transition-colors"
      >
        Unlock
      </button>
      <p id="pg-error" style="display:none" class="text-red-400 text-sm">Incorrect password.</p>
    </form>
  </div>
</div>

<div id="pg-content" style="display:none">
  <slot />
</div>

<script define:vars={{ password }}>
  const key = "pg_" + window.location.pathname;
  const gate = document.getElementById("pg-gate");
  const content = document.getElementById("pg-content");
  const form = document.getElementById("pg-form");
  const input = document.getElementById("pg-input");
  const error = document.getElementById("pg-error");

  function unlock() {
    gate.style.display = "none";
    content.style.display = "";
  }

  if (sessionStorage.getItem(key) === password) {
    unlock();
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    if (input.value === password) {
      sessionStorage.setItem(key, password);
      unlock();
    } else {
      error.style.display = "";
      input.value = "";
    }
  });
</script>
